# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (monorepo: any depth)
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage/

# next.js (monorepo: any depth)
**/.next/
**/out/

# turborepo
**/.turbo/

# build outputs
**/dist/
**/build/

# misc
.DS_Store
*.pem

# claude.ai/design raw export dumps (canonical copies live in docs/design/reference/)
/web/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code tooling caches
.claude/tdd-guard/
.claude/scheduled_tasks.lock
.claude/worktrees/

# playwright e2e test artifacts
**/test-results/

# supabase local-only config (CI는 supabase start로 동적 default 사용)
/supabase/

# playwright MCP one-off verification artifacts (visual regression scratch space)
.playwright-mcp/
/design-system-full.png
/handoff-original-full.png
/s[0-9]*.png
/[0-9][0-9]-*.png
/prod-*.png
store-detail-after-pr166.png
.gstack/
