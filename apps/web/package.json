    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "seed:demo": "pnpm --filter @hesya/database exec tsx ../../apps/web/scripts/seed-beta-demo.ts",
