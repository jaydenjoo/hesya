{
  "name": "@hesya/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4200",
    "build": "next build",
    "start": "next start -p 4200",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
