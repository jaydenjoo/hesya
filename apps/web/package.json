    "inject:fake-inbound": "pnpm --filter @hesya/database exec tsx ../../apps/web/scripts/inject-fake-inbound.ts",
    "dev:demo": "bash scripts/dev-demo.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@hesya/auth": "workspace:*",
    "@hesya/database": "workspace:*",
    "@hesya/design-tokens": "workspace:*",
    "@hesya/shared-types": "workspace:*",
    "@hesya/shared-ui": "workspace:*",
    "@hesya/translations": "workspace:*",
    "@posthog/next": "^0.1.0",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.105.1",
    "@upstash/qstash": "^2.10.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "openai": "^6.36.0",
    "pretendard": "^1.3.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "shadcn": "^4.6.0",
