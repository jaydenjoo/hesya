{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(jq:*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [[ \"$CLAUDE_TOOL_PATH\" =~ \\.(ts|tsx)$ ]]; then pnpm tsc --noEmit 2>&1 | head -20; fi'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cmd=\"$CLAUDE_TOOL_INPUT_command\"; if echo \"$cmd\" | grep -qE \"DROP TABLE|TRUNCATE TABLE|DELETE FROM.*WHERE 1=1\"; then echo \"⛔ 위험 SQL 차단: $cmd\"; exit 1; fi; exit 0'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '[ -f PROGRESS.md ] && head -30 PROGRESS.md || true'"
          }
        ]
      }
    ]
  }
}
